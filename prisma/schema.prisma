generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Business {
  id                  String    @id @default(cuid())
  name                String
  ownerName           String?
  tagline             String?
  industry            String
  businessType        String
  employeeRange       String
  revenueRange        String?
  targetCustomer      String?
  businessAge         String?
  growthTrajectory    String?
  staffStructure      String?
  hasSeparateDepts    Boolean   @default(true)
  softwareSpend       String?
  aiComfortLevel      String?
  aiBudget            String?
  aiPrefBuiltVsCustom String?
  primaryContact      String?
  inquiryVolume       String?
  hasKnowledgeBase    String?
  avgResponseTime     String?
  hasDocumentedSOPs   String?
  meetingHoursPerWeek String?
  reportingFrequency  String?
  reportCreator       String?
  dataBasedDecisions  String?
  topPriority90Days   String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  departments       Department[]
  processes         Process[]
  painPoints        PainPoint[]
  tools             ToolUsed[]
  goals             BusinessGoal[]
  manualTasks       ManualTask[]
  bottlenecks       Bottleneck[]
  aiOpportunities   AiOpportunity[]
  onboardingSession OnboardingSession?
}

model Department {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String   @default("#6366f1")
  icon        String?
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  status      String   @default("active")
  headcount   Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  processes       Process[]
  painPoints      PainPoint[]
  aiOpportunities AiOpportunity[]
}

model Process {
  id                  String   @id @default(cuid())
  businessId          String
  departmentId        String
  name                String
  description         String?
  frequency           String?
  timeSpentHrsPerWeek Float?
  peopleInvolved      Int?
  toolUsed            String?
  isManual            Boolean  @default(true)
  isRepetitive        Boolean  @default(false)
  involvesDataEntry   Boolean  @default(false)
  involvesEmails      Boolean  @default(false)
  involvesReporting   Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model ToolUsed {
  id              String  @id @default(cuid())
  businessId      String
  name            String
  category        String
  monthlyCost     Float?
  isManualProcess Boolean @default(false)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ManualTask {
  id         String @id @default(cuid())
  businessId String
  task       String

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PainPoint {
  id           String   @id @default(cuid())
  businessId   String
  departmentId String?
  description  String
  severity     String   @default("medium")
  category     String?
  createdAt    DateTime @default(now())

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
}

model Bottleneck {
  id         String  @id @default(cuid())
  businessId String
  type       String
  freeText   String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessGoal {
  id         String  @id @default(cuid())
  businessId String
  goal       String
  timeframe  String?
  priority   Int     @default(1)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model AiOpportunity {
  id                   String    @id @default(cuid())
  businessId           String
  departmentId         String?
  title                String
  description          String
  impactType           String
  estimatedHoursSaved  Float?
  estimatedCostSaved   Float?
  implementationEffort String?
  category             String?
  agentName            String?
  agentDescription     String?
  agentTools           String?
  setupComplexity      String?
  dismissedAt          DateTime?
  pinned               Boolean   @default(false)
  roadmapStatus        String    @default("backlog")
  generatedAt          DateTime  @default(now())
  source               String    @default("claude")

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
}

model OnboardingSession {
  id          String   @id @default(cuid())
  businessId  String   @unique
  answers     String
  currentStep Int      @default(0)
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
